{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PageWeave",
  "version": "0.1.0",
  "identifier": "com.pageweave.app",
  "build": {
    "beforeDevCommand": "node node_modules/vite/bin/vite.js",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PageWeave",
        "label": "main",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": [
      "../sidecar/dist/babeldoc-sidecar/babeldoc-sidecar"
    ],
    "resources": {
      "../sidecar/dist/babeldoc-sidecar/": "babeldoc-sidecar/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2NDdDRDcyNzQ1RTAwM0MKUldROEFGNTBjczFINW9lTm0rWGtkUkVES1lGYndENWZuN0o1WlRkTHlNbWpPQzc2WEY3YlhYRzAK",
      "endpoints": [
        "https://github.com/jhxxr/PageWeave/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
